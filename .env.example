# Public runtime endpoint for form delivery.
# Example: https://api.example.com/forms/pastodel
PUBLIC_PASTODEL_FORMS_ENDPOINT=

# Client-side timeout for form delivery request (milliseconds).
PUBLIC_PASTODEL_FORMS_TIMEOUT_MS=10000

# Stub delivery mode is for local/dev diagnostics only.
# Keep 0 in production.
PUBLIC_ALLOW_FORM_STUB=0
