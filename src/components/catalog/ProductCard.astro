---
import { getImage } from 'astro:assets';
import type { ProductRecord } from '@/data/product-types';
import ProductMeta from '@/components/product/ProductMeta.astro';

interface Props {
  product: ProductRecord;
}

const { product } = Astro.props;

const cardSizes = '(max-width: 719px) calc(100vw - 72px), (max-width: 959px) calc(50vw - 54px), (max-width: 1279px) calc((100vw - 160px) / 3), 290px';
const cardWidths = [240, 320, 400, 520];

const homeImage = await getImage({
  src: product.retail.imageAsset,
  alt: product.retail.title,
  widths: cardWidths,
  sizes: cardSizes,
  quality: 58,
  format: 'webp',
  loading: 'lazy'
});

const horecaImage = await getImage({
  src: product.horeca.imageAsset,
  alt: product.horeca.title,
  widths: cardWidths,
  sizes: cardSizes,
  quality: 58,
  format: 'webp',
  loading: 'lazy'
});

const homeSrcSet = homeImage.srcSet.values.length > 0 ? homeImage.srcSet.attribute : undefined;
const horecaSrcSet = horecaImage.srcSet.values.length > 0 ? horecaImage.srcSet.attribute : undefined;
---
<article class="catalog-card" data-catalog-card data-horeca-card="true" data-category={product.category} data-line={product.line} data-ingredients={product.ingredientsTag} data-calories={String(product.caloriesPer100)}>
  <a class="catalog-card__media" href={product.retail.route} aria-hidden="true" tabindex="-1" data-card-link data-home-href={product.retail.route} data-business-href={product.horeca.route}>
    <div class="product-image product-image--card">
      <img
        src={homeImage.src}
        srcset={homeSrcSet}
        sizes={cardSizes}
        width={homeImage.attributes.width}
        height={homeImage.attributes.height}
        alt={product.retail.title}
        loading="lazy"
        decoding="async"
        data-card-image
        data-home-src={homeImage.src}
        data-home-srcset={homeSrcSet}
        data-home-alt={product.retail.title}
        data-business-src={horecaImage.src}
        data-business-srcset={horecaSrcSet}
        data-business-alt={product.horeca.title}
      />
    </div>
  </a>

  <div class="catalog-card__body">
    <div class="catalog-card__meta">
      <span class="pill">{product.line === 'casa' ? 'Классика на каждый день' : product.line === 'chef' ? 'Сытные блюда' : 'Лёгкие вкусы'}</span>
      <span class="catalog-card__weight" data-card-weight data-weight-home={product.retail.weightLabel} data-weight-business={product.horeca.weightLabel}>{product.retail.weightLabel}</span>
    </div>

    <h3>
      <a
        href={product.retail.route}
        data-card-title
        data-card-link
        data-home-href={product.retail.route}
        data-business-href={product.horeca.route}
        data-title-home={product.retail.title}
        data-title-business={product.horeca.title}
      >
        {product.retail.title}
      </a>
    </h3>

    <p class="catalog-card__desc">{product.retail.description}</p>

    <ProductMeta stats={product.retail.stats} />

    <div class="catalog-card__actions" data-home-actions>
      <a class="button button--text" href="/gde-kupit/">Где купить</a>
    </div>

    <div class="catalog-card__actions catalog-card__actions--business" data-business-actions hidden>
      <a class="button button--secondary" href={product.horeca.route} data-card-link data-home-href={product.retail.route} data-business-href={product.horeca.route}>Карточка HoReCa</a>
      <a class="button button--ghost" href={product.horeca.cta.href}>Запросить условия</a>
      <p class="catalog-card__note">{product.audienceSupportNote}</p>
    </div>
  </div>
</article>
