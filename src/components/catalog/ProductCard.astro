---
import { Picture, getImage } from "astro:assets";
import type { ProductRecord } from "@/data/product-types";
import ProductMeta from "@/components/product/ProductMeta.astro";

interface Props {
  product: ProductRecord;
  priority?: boolean;
}

const { product, priority = false } = Astro.props;

const cardSizes =
  "(max-width: 719px) calc(100vw - 84px), (max-width: 959px) calc(50vw - 62px), (max-width: 1279px) calc((100vw - 184px) / 3), 248px";
const cardWidths = [180, 240, 320, 400];

const homeWebp = await getImage({
  src: product.retail.imageAsset,
  alt: product.retail.title,
  widths: cardWidths,
  sizes: cardSizes,
  quality: 54,
  format: "webp",
  loading: "lazy",
});

const horecaWebp = await getImage({
  src: product.horeca.imageAsset,
  alt: product.horeca.title,
  widths: cardWidths,
  sizes: cardSizes,
  quality: 54,
  format: "webp",
  loading: "lazy",
});

const homeAvif = await getImage({
  src: product.retail.imageAsset,
  alt: product.retail.title,
  widths: cardWidths,
  sizes: cardSizes,
  quality: 46,
  format: "avif",
  loading: "lazy",
});

const horecaAvif = await getImage({
  src: product.horeca.imageAsset,
  alt: product.horeca.title,
  widths: cardWidths,
  sizes: cardSizes,
  quality: 46,
  format: "avif",
  loading: "lazy",
});

const homeWebpSrcSet =
  homeWebp.srcSet.values.length > 0 ? homeWebp.srcSet.attribute : undefined;
const horecaWebpSrcSet =
  horecaWebp.srcSet.values.length > 0 ? horecaWebp.srcSet.attribute : undefined;
const homeAvifSrcSet =
  homeAvif.srcSet.values.length > 0 ? homeAvif.srcSet.attribute : undefined;
const horecaAvifSrcSet =
  horecaAvif.srcSet.values.length > 0 ? horecaAvif.srcSet.attribute : undefined;
---

<article
  class="catalog-card"
  data-catalog-card
  data-horeca-card="true"
  data-category={product.category}
  data-line={product.line}
  data-ingredients={product.ingredientsTag}
  data-calories={String(product.caloriesPer100)}
>
  <a
    class="catalog-card__media"
    href={product.retail.route}
    aria-hidden="true"
    tabindex="-1"
    data-card-link
    data-home-href={product.retail.route}
    data-business-href={product.horeca.route}
  >
    <div class="product-image product-image--card">
      <Picture
        src={product.retail.imageAsset}
        alt={product.retail.title}
        formats={["avif", "webp"]}
        fallbackFormat="webp"
        widths={cardWidths}
        sizes={cardSizes}
        quality={54}
        loading={priority ? "eager" : "lazy"}
        fetchpriority={priority ? "high" : "auto"}
        pictureAttributes={{
          "data-card-picture": "",
          "data-home-avif-set": homeAvifSrcSet,
          "data-business-avif-set": horecaAvifSrcSet,
          "data-home-webp-srcset": homeWebpSrcSet,
          "data-business-webp-srcset": horecaWebpSrcSet,
        }}
        data-card-image
        data-home-image={homeWebp.src}
        data-home-image-set={homeWebpSrcSet}
        data-home-alt={product.retail.title}
        data-business-image={horecaWebp.src}
        data-business-image-set={horecaWebpSrcSet}
        data-business-alt={product.horeca.title}
      />
    </div>
  </a>

  <div class="catalog-card__body">
    <div class="catalog-card__meta">
      <span class="pill"
        >{
          product.line === "casa"
            ? "Классика на каждый день"
            : product.line === "chef"
              ? "Сытные блюда"
              : "Лёгкие вкусы"
        }</span
      >
      <span
        class="catalog-card__weight"
        data-card-weight
        data-weight-home={product.retail.weightLabel}
        data-weight-business={product.horeca.weightLabel}
        >{product.retail.weightLabel}</span
      >
    </div>

    <h3>
      <a
        href={product.retail.route}
        data-card-title
        data-card-link
        data-home-href={product.retail.route}
        data-business-href={product.horeca.route}
        data-title-home={product.retail.title}
        data-title-business={product.horeca.title}
      >
        {product.retail.title}
      </a>
    </h3>

    <p class="catalog-card__desc">{product.retail.description}</p>

    <ProductMeta stats={product.retail.stats} />

    <div class="catalog-card__actions" data-home-actions>
      <a class="button button--text" href="/gde-kupit/">Где купить</a>
    </div>

    <div
      class="catalog-card__actions catalog-card__actions--business"
      data-business-actions
      hidden
    >
      <a
        class="button button--secondary"
        href={product.horeca.route}
        data-card-link
        data-home-href={product.retail.route}
        data-business-href={product.horeca.route}>Карточка HoReCa</a
      >
      <a class="button button--ghost" href={product.horeca.cta.href}
        >Запросить условия</a
      >
      <p class="catalog-card__note">{product.audienceSupportNote}</p>
    </div>
  </div>
</article>
