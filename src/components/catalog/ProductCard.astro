---
import type { ProductRecord } from "@/data/product-types";
import ProductMeta from "@/components/product/ProductMeta.astro";

interface Props {
  product: ProductRecord;
  priority?: boolean;
}

const { product, priority = false } = Astro.props;
---

<article
  class="catalog-card"
  data-catalog-card
  data-horeca-card="true"
  data-category={product.category}
  data-line={product.line}
  data-ingredients={product.ingredientsTag}
  data-calories={String(product.caloriesPer100)}
>
  <a
    class="catalog-card__media"
    href={product.retail.route}
    aria-hidden="true"
    tabindex="-1"
    data-card-link
    data-home-href={product.retail.route}
    data-business-href={product.horeca.route}
  >
    <div class="product-image product-image--card">
      <img
        src={product.retail.imageAsset.src}
        alt={product.retail.title}
        width={product.retail.imageAsset.width}
        height={product.retail.imageAsset.height}
        loading={priority ? "eager" : "lazy"}
        fetchpriority={priority ? "high" : "auto"}
        decoding="async"
        data-card-image
        data-home-image={product.retail.imageAsset.src}
        data-home-alt={product.retail.title}
        data-business-image={product.horeca.imageAsset.src}
        data-business-alt={product.horeca.title}
      />
    </div>
  </a>

  <div class="catalog-card__body">
    <div class="catalog-card__meta">
      <span class="pill"
        >{
          product.line === "casa"
            ? "Классика на каждый день"
            : product.line === "chef"
              ? "Сытные блюда"
              : "Лёгкие вкусы"
        }</span
      >
      <span
        class="catalog-card__weight"
        data-card-weight
        data-weight-home={product.retail.weightLabel}
        data-weight-business={product.horeca.weightLabel}
        >{product.retail.weightLabel}</span
      >
    </div>

    <h3>
      <a
        href={product.retail.route}
        data-card-title
        data-card-link
        data-home-href={product.retail.route}
        data-business-href={product.horeca.route}
        data-title-home={product.retail.title}
        data-title-business={product.horeca.title}
      >
        {product.retail.title}
      </a>
    </h3>

    <p class="catalog-card__desc">{product.retail.description}</p>

    <ProductMeta stats={product.retail.stats} />

    <div class="catalog-card__actions" data-home-actions>
      <a class="button button--text" href="/gde-kupit/">Где купить</a>
    </div>

    <div
      class="catalog-card__actions catalog-card__actions--business"
      data-business-actions
      hidden
    >
      <a
        class="button button--secondary"
        href={product.horeca.route}
        data-card-link
        data-home-href={product.retail.route}
        data-business-href={product.horeca.route}>Карточка HoReCa</a
      >
      <a class="button button--ghost" href={product.horeca.cta.href}
        >Запросить условия</a
      >
      <p class="catalog-card__note">{product.audienceSupportNote}</p>
    </div>
  </div>
</article>
