---
import type { ProductRecord } from "@/data/product-types";
import ProductMeta from "@/components/product/ProductMeta.astro";
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  product: ProductRecord;
  priority?: boolean;
}

const { product, priority = false } = Astro.props;

const CARD_SIZES =
  "(max-width: 719px) calc(100vw - 68px), (max-width: 959px) calc(50vw - 56px), (max-width: 1279px) calc(33vw - 44px), 300px";
const CARD_WIDTHS = [260, 360, 520];

async function buildResponsiveImageData(image: ImageMetadata) {
  const variants = await Promise.all(
    CARD_WIDTHS.map((width) =>
      getImage({
        src: image,
        width,
        format: "webp",
        quality: 70,
      }),
    ),
  );

  return {
    src: variants[0].src,
    srcset: variants.map((variant) => `${variant.src} ${variant.options.width}w`).join(", "),
  };
}

const [homeImage, businessImage] = await Promise.all([
  buildResponsiveImageData(product.retail.imageAsset),
  buildResponsiveImageData(product.horeca.imageAsset),
]);
---

<article
  class="catalog-card"
  data-catalog-card
  data-horeca-card="true"
  data-category={product.category}
  data-line={product.line}
  data-ingredients={product.ingredientsTag}
  data-calories={String(product.caloriesPer100)}
>
  <a
    class="catalog-card__media"
    href={product.retail.route}
    aria-hidden="true"
    tabindex="-1"
    data-card-link
    data-home-href={product.retail.route}
    data-business-href={product.horeca.route}
  >
    <div class="product-image product-image--card">
      <img
        src={homeImage.src}
        srcset={homeImage.srcset}
        sizes={CARD_SIZES}
        alt={product.retail.title}
        width={CARD_WIDTHS[0]}
        height={Math.round((CARD_WIDTHS[0] * product.retail.imageAsset.height) / product.retail.imageAsset.width)}
        loading={priority ? "eager" : "lazy"}
        fetchpriority={priority ? "high" : "auto"}
        decoding="async"
        data-card-image
        data-home-image={homeImage.src}
        data-home-srcset={homeImage.srcset}
        data-home-sizes={CARD_SIZES}
        data-home-alt={product.retail.title}
        data-business-image={businessImage.src}
        data-business-srcset={businessImage.srcset}
        data-business-sizes={CARD_SIZES}
        data-business-alt={product.horeca.title}
      />
    </div>
  </a>

  <div class="catalog-card__body">
    <div class="catalog-card__meta">
      <span class="pill"
        >{
          product.line === "casa"
            ? "Классика на каждый день"
            : product.line === "chef"
              ? "Сытные блюда"
              : "Лёгкие вкусы"
        }</span
      >
      <span
        class="catalog-card__weight"
        data-card-weight
        data-weight-home={product.retail.weightLabel}
        data-weight-business={product.horeca.weightLabel}
        >{product.retail.weightLabel}</span
      >
    </div>

    <h3>
      <a
        href={product.retail.route}
        data-card-title
        data-card-link
        data-home-href={product.retail.route}
        data-business-href={product.horeca.route}
        data-title-home={product.retail.title}
        data-title-business={product.horeca.title}
      >
        {product.retail.title}
      </a>
    </h3>

    <p class="catalog-card__desc">{product.retail.description}</p>

    <ProductMeta stats={product.retail.stats} />

    <div class="catalog-card__actions" data-home-actions>
      <a class="button button--text" href="/gde-kupit/">Где купить</a>
    </div>

    <div
      class="catalog-card__actions catalog-card__actions--business"
      data-business-actions
      hidden
    >
      <a
        class="button button--secondary"
        href={product.horeca.route}
        data-card-link
        data-home-href={product.retail.route}
        data-business-href={product.horeca.route}>Карточка HoReCa</a
      >
      <a class="button button--ghost" href={product.horeca.cta.href}
        >Запросить условия</a
      >
      <p class="catalog-card__note">{product.audienceSupportNote}</p>
    </div>
  </div>
</article>
