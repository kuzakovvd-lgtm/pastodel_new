---
import { getImage } from "astro:assets";
import type { ProductRecord } from "@/data/product-types";
import {
  getProductCardView,
  type ProductCardAction,
  type ProductCardAudience,
} from "@/data/product-card-view";
import ProductMeta from "@/components/product/ProductMeta.astro";

interface Props {
  product: ProductRecord;
  priority?: boolean;
  audience?: ProductCardAudience;
}

const { product, priority = false, audience } = Astro.props;
const catalogSwitchMode = audience === undefined;
const view = getProductCardView(product, audience ?? "consumer");
const consumerView = catalogSwitchMode
  ? getProductCardView(product, "consumer")
  : view;
const horecaView = catalogSwitchMode
  ? getProductCardView(product, "horeca")
  : view;

const CARD_SIZES =
  "(max-width: 719px) calc(100vw - 68px), (max-width: 959px) calc(50vw - 56px), (max-width: 1279px) calc(33vw - 44px), 300px";
const CARD_WIDTHS = [220, 300, 420, 520];
const imageOptions = {
  format: "webp",
  widths: CARD_WIDTHS,
  sizes: CARD_SIZES,
  quality: 72,
} as const;

const primaryImage = await getImage({ src: view.image, ...imageOptions });
const horecaImage = catalogSwitchMode
  ? await getImage({ src: horecaView.image, ...imageOptions })
  : undefined;

const actionClass = (action: ProductCardAction): string => {
  if (action.style === "primary") return "button button--secondary";
  if (action.style === "secondary") return "button button--ghost";
  return "button button--text";
};
---

<article
  class="catalog-card"
  data-catalog-card={catalogSwitchMode ? "" : undefined}
  data-horeca-card={catalogSwitchMode ? "true" : undefined}
  data-category={product.category}
  data-line={product.line}
  data-ingredients={product.ingredientsTag}
  data-calories={String(product.caloriesPer100)}
>
  <a
    class="catalog-card__media"
    href={view.mediaHref}
    aria-hidden="true"
    tabindex="-1"
    data-card-media-link={catalogSwitchMode ? "" : undefined}
    data-consumer-href={catalogSwitchMode
      ? consumerView.mediaHref
      : undefined}
    data-horeca-href={catalogSwitchMode ? horecaView.mediaHref : undefined}
  >
    <div class="product-image product-image--card">
      <img
        src={primaryImage.src}
        srcset={primaryImage.srcSet.attribute}
        sizes={CARD_SIZES}
        alt={view.imageAlt}
        width={primaryImage.attributes.width}
        height={primaryImage.attributes.height}
        loading={priority ? "eager" : "lazy"}
        fetchpriority={priority ? "high" : "auto"}
        decoding="async"
        data-card-image={catalogSwitchMode ? "" : undefined}
        data-consumer-src={catalogSwitchMode ? primaryImage.src : undefined}
        data-consumer-srcset={catalogSwitchMode
          ? primaryImage.srcSet.attribute
          : undefined}
        data-consumer-sizes={catalogSwitchMode ? CARD_SIZES : undefined}
        data-consumer-alt={catalogSwitchMode
          ? consumerView.imageAlt
          : undefined}
        data-horeca-src={horecaImage?.src}
        data-horeca-srcset={horecaImage?.srcSet.attribute}
        data-horeca-sizes={catalogSwitchMode ? CARD_SIZES : undefined}
        data-horeca-alt={catalogSwitchMode ? horecaView.imageAlt : undefined}
      />
    </div>
  </a>

  <div class="catalog-card__body">
    <div class="catalog-card__meta">
      <span
        class="pill"
        data-card-badge={catalogSwitchMode ? "" : undefined}
        data-consumer-text={catalogSwitchMode
          ? consumerView.badge
          : undefined}
        data-horeca-text={catalogSwitchMode ? horecaView.badge : undefined}
        >{view.badge}</span
      >
      <span
        class="catalog-card__weight"
        data-card-weight={catalogSwitchMode ? "" : undefined}
        data-consumer-text={catalogSwitchMode
          ? consumerView.weightLabel
          : undefined}
        data-horeca-text={catalogSwitchMode
          ? horecaView.weightLabel
          : undefined}>{view.weightLabel}</span
      >
    </div>

    <h3>
      <a
        href={view.mediaHref}
        data-card-title-link={catalogSwitchMode ? "" : undefined}
        data-consumer-href={catalogSwitchMode
          ? consumerView.mediaHref
          : undefined}
        data-horeca-href={catalogSwitchMode ? horecaView.mediaHref : undefined}
        data-consumer-text={catalogSwitchMode ? consumerView.title : undefined}
        data-horeca-text={catalogSwitchMode
          ? horecaView.title
          : undefined}
      >
        {view.title}
      </a>
    </h3>

    <p
      class="catalog-card__desc"
      data-card-description={catalogSwitchMode ? "" : undefined}
      data-consumer-text={catalogSwitchMode
        ? consumerView.description
        : undefined}
      data-horeca-text={catalogSwitchMode
        ? horecaView.description
        : undefined}
    >
      {view.description}
    </p>

    {
      catalogSwitchMode ? (
        <>
          <div data-audience-content="consumer">
            <ProductMeta stats={consumerView.stats} />
          </div>
          <div data-audience-content="horeca" hidden>
            <ProductMeta stats={horecaView.stats} />
          </div>
        </>
      ) : (
        <ProductMeta stats={view.stats} />
      )
    }

    {
      catalogSwitchMode ? (
        <>
          <div
            class="catalog-card__actions"
            data-audience-content="consumer"
          >
            {consumerView.actions.map((action) => (
              <a class={actionClass(action)} href={action.href}>
                {action.label}
              </a>
            ))}
          </div>

          <div
            class="catalog-card__actions"
            data-audience-content="horeca"
            hidden
          >
            {horecaView.actions.map((action) => (
              <a class={actionClass(action)} href={action.href}>
                {action.label}
              </a>
            ))}
          </div>
        </>
      ) : (
        <div class="catalog-card__actions">
          {view.actions.map((action) => (
            <a class={actionClass(action)} href={action.href}>
              {action.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
