---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  compact?: boolean;
}

const { eyebrow, title, lead, compact = false } = Astro.props;
---
<div class:list={["section-head", compact && "section-head--compact"]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {lead && <p class="section-lead">{lead}</p>}
</div>
