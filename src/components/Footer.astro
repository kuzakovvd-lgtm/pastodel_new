---
import { mainNav } from '@/data/navigation';
import { Image } from 'astro:assets';
import logoFooter from '@/assets/branding/logo-pastodel-clean.webp';
---
<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <a class="brand-mark brand-mark--footer" href="/" aria-label="Pastodel — на главную">
        <Image
          src={logoFooter}
          alt="Pastodel"
          widths={[180, 260, 340]}
          sizes="(max-width: 719px) min(100vw - 32px, 260px), 260px"
          format="webp"
          quality={68}
          class="brand-mark__image"
          loading="lazy"
        />
      </a>
      <p class="site-footer__text">Паста, ризотто и паэлья — вкусный ужин за 7 минут.</p>
      <a class="button" href="/kontakty/">Написать нам</a>
    </div>

    <div class="site-footer__links">
      <p class="site-footer__title">Разделы</p>
      <ul class="site-footer__list">
        {mainNav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
        <li><a href="/politika-konfidentsialnosti/">Политика конфиденциальности</a></li>
      </ul>
    </div>

    <div class="site-footer__meta">
      <p>© 2026 Pastodel</p>
    </div>
  </div>
</footer>
