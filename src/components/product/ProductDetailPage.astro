---
import type { ProductAudience, ProductRecord } from "@/data/product-types";
import {
  getAudienceData,
  getCategoryLabel,
  getProducts,
} from "@/data/product-utils";
import ProductImage from "@/components/product/ProductImage.astro";
import PrepTabs from "@/components/product/PrepTabs.astro";
import ProductCard from "@/components/catalog/ProductCard.astro";

interface Props {
  product: ProductRecord;
  audience: ProductAudience;
}

const { product, audience } = Astro.props;
const data = getAudienceData(product, audience);
const categoryLabel = getCategoryLabel(product.category);
const recommendations = getProducts()
  .filter((item) => item.slug !== product.slug)
  .slice(0, 4);
const detailFacts = Array.from(
  new Set([`${data.weightLabel} в упаковке`, data.packLabel, ...data.facts]),
);
const breadcrumbs = [
  { href: "/", label: "Главная" },
  { href: "/katalog/", label: "Каталог" },
  { href: "/katalog/", label: categoryLabel },
  { href: data.route, label: data.h1 },
];
---

<section class="product-page section section--compact">
  <div class="container">
    <nav class="breadcrumbs-nav" aria-label="Хлебные крошки">
      <ol class="breadcrumbs">
        {
          breadcrumbs.map((crumb, index) => (
            <li>
              {index === breadcrumbs.length - 1 ? (
                <span aria-current="page">{crumb.label}</span>
              ) : (
                <a href={crumb.href}>{crumb.label}</a>
              )}
            </li>
          ))
        }
      </ol>
    </nav>

    <div class="product-hero-grid">
      <article class="surface-card product-hero-image">
        <ProductImage
          image={data.imageAsset}
          alt={data.h1}
          className="product-image product-image--detail"
          loading="eager"
          fetchpriority="high"
          sizes="(max-width: 719px) calc(100vw - 52px), (max-width: 959px) calc(50vw - 40px), 42vw"
          widths={[420, 620, 820, 1080]}
          quality={72}
        />
      </article>

      <article class="surface-card product-summary">
        <p class="eyebrow">{categoryLabel}</p>
        <h1>{data.h1}</h1>
        <p class="product-summary__descriptor">{data.heroDescriptor}</p>
        <p class="product-summary__text">{data.heroSummary}</p>
        <div class="product-meta">
          {data.stats.map((item) => <span>{item}</span>)}
        </div>
      </article>
    </div>
  </div>
</section>

<section class="section section--compact">
  <div class="container product-info-grid">
    <article class="surface-card">
      <p class="eyebrow">Состав</p>
      <h2>Состав и КБЖУ</h2>
      <div class="ingredient-chips">
        {data.ingredientChips.map((ingredient) => <span>{ingredient}</span>)}
      </div>
      <div class="composition-copy">
        <h3>Полный состав</h3>
        <p>{data.fullComposition}</p>
      </div>
      <div class="nutrition-panels">
        <article class="nutrition-panel">
          <h3>На 100 г</h3>
          <div class="nutrition-grid">
            {
              Object.entries(data.nutrition100).map(([key, value]) => (
                <div>
                  <>
                    <span>{key}</span>
                    <strong>{value}</strong>
                  </>
                </div>
              ))
            }
          </div>
        </article>
        <article class="nutrition-panel">
          <h3>{`На порцию ${data.weightLabel}`}</h3>
          <div class="nutrition-grid">
            {
              Object.entries(data.nutritionPortion).map(([key, value]) => (
                <div>
                  <>
                    <span>{key}</span>
                    <strong>{value}</strong>
                  </>
                </div>
              ))
            }
          </div>
        </article>
      </div>
    </article>

    <article class="surface-card">
      <p class="eyebrow">Кратко</p>
      <h2>Что важно знать</h2>
      <ul class="detail-list">
        {detailFacts.map((fact) => <li>{fact}</li>)}
      </ul>
    </article>
  </div>
</section>

<section class="section section--compact">
  <div class="container">
    <article class="surface-card product-prep-card">
      <p class="eyebrow">Разогрев</p>
      <h2>Как приготовить</h2>
      <PrepTabs microwave={data.prep.microwave} pan={data.prep.pan} />
    </article>
  </div>
</section>

<section class="section section--compact">
  <div class="container">
    <article class="surface-card cta-strip">
      <p class="eyebrow">Для бизнеса</p>
      <h2>Нужна коммерческая консультация по позиции?</h2>
      <p>
        Оставьте заявку, и команда Pastodel вернётся с условиями и следующими
        шагами.
      </p>
      <div class="button-group">
        <a class="button" href={data.cta.href}>{data.cta.label}</a>
        <a class="button button--secondary" href="/katalog/"
          >Вернуться в каталог</a
        >
      </div>
    </article>
  </div>
</section>

<section class="section section--compact">
  <div class="container">
    <p class="eyebrow">Ассортимент</p>
    <h2>Попробуйте ещё</h2>
    <div class="catalog-grid">
      {recommendations.map((item) => <ProductCard product={item} />)}
    </div>
  </div>
</section>
