---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageIntro from '@/components/common/PageIntro.astro';
import SectionHead from '@/components/common/SectionHead.astro';
import universalIntro from '@/assets/page-intro/universal.KhHo-xsH_ZRJCIk.webp';
---
<BaseLayout title="Политика конфиденциальности — Pastodel" description="Базовая legal-страница для форм и пользовательских сценариев сайта Pastodel.">
  <PageIntro
    eyebrow="Legal"
    title="Политика конфиденциальности"
    description="Текст требует финальной юридической проверки перед публикацией."
    image={universalIntro}
    imageAlt="Иллюстрация Pastodel для страницы политики конфиденциальности"
    breadcrumbs={[{ href: '/', label: 'Главная' }, { label: 'Политика конфиденциальности' }]}
  />

  <section class="section section--tight-top">
    <div class="container simple-stack">
      <article class="surface-card info-card"><SectionHead compact eyebrow="Статус страницы" title="Текст требует финальной юрпроверки" lead="До публикации подтверждённых реквизитов и финальной схемы обработки данных страница считается legal-заготовкой." /></article>
      <article class="surface-card info-card"><h3>1. Общая рамка</h3><p>Сайт Pastodel может использовать формы для приёма обращений от покупателей, партнёров и пользователей.</p><h3>2. Какие данные могут запрашиваться</h3><p>Имя, компания, способ обратной связи и текст сообщения в объёме, который пользователь указывает самостоятельно.</p><h3>3. Для чего используются данные</h3><p>Для ответа на обращение, организации обратной связи, продолжения B2B-диалога или уточнения вопроса по продукции.</p><h3>4. Ограничение</h3><p>До подключения реального обработчика формы и публикации реквизитов текст является структурной заготовкой.</p></article>
      <article class="surface-card info-card"><SectionHead compact eyebrow="Связанные разделы" title="Формы и контактные маршруты" /><div class="button-group"><a class="button button--secondary" href="/kontakty/">Контакты</a><a class="button button--secondary" href="/stat-partnerom/">Стать партнёром</a></div></article>
    </div>
  </section>
</BaseLayout>
