---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageIntro from '@/components/common/PageIntro.astro';
import SectionHead from '@/components/common/SectionHead.astro';
import FormRuntime from '@/components/forms/FormRuntime.astro';
import partnerIntro from '@/assets/page-intro/partneram.DMd1JByY_1rJtxO.webp';
import { Image } from 'astro:assets';
import { getProductCardView } from '@/data/product-card-view';
import { getCategoryLabel, getProductBySlug } from '@/data/product-utils';

const exampleSlugs = ['alfredo-kuritsa', 'karbonara', 'mak-end-chiz'] as const;
const productExamples = exampleSlugs.map((slug) => {
  const product = getProductBySlug(slug);
  if (!product) throw new Error(`Missing retail product example: ${slug}`);

  return {
    category: getCategoryLabel(product.category),
    view: getProductCardView(product, 'consumer')
  };
});
---
<BaseLayout
  title="Решения для сетевого ритейла Pastodel — ассортимент и условия запуска"
  description="Готовые ужины PASTODEL для сетевого ритейла: паста, ризотто и паэлья 400 г. Обсудите ассортимент и формат сотрудничества для вашей сети."
>
  <PageIntro
    eyebrow="Сетевой ритейл"
    title="Готовые ужины из морозилки для вашей полки"
    description="Линейка пасты, ризотто и паэльи в формате 400 г. Обсудим ассортимент и формат сотрудничества под задачу вашей сети."
    image={partnerIntro}
    imageAlt="Иллюстрация Pastodel для страницы партнёров"
    breadcrumbs={[{ href: '/', label: 'Главная' }, { label: 'Партнёрам' }]}
    actions={[
      { href: '#partner-form', label: 'Обсудить ассортимент' },
      { href: '/katalog/', label: 'Смотреть каталог', secondary: true }
    ]}
  />

  <section class="section section--tight-top">
    <div class="container">
      <SectionHead eyebrow="Первый разговор" title="Что можно обсудить" />
      <div class="simple-grid simple-grid--three">
        <article class="surface-card info-card"><h3>Ассортимент</h3><p>Паста, ризотто и паэлья в едином формате 400 г.</p></article>
        <article class="surface-card info-card"><h3>Формат сотрудничества</h3><p>Обсудим задачу сети, интересующие позиции и возможный формат первого запуска.</p></article>
        <article class="surface-card info-card"><h3>Следующие шаги</h3><p>Свяжемся по указанным контактам и уточним, какая информация нужна для дальнейшего обсуждения.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead eyebrow="Ассортимент" title="Примеры позиций" lead="На сайте представлен актуальный ассортимент PASTODEL. Ниже — несколько позиций линейки." />
      <div class="retail-product-grid">
        {productExamples.map(({ category, view }) => (
          <article class="surface-card retail-product-card">
            <div class="retail-product-card__image">
              <Image
                src={view.image}
                alt={view.imageAlt}
                widths={[220, 320, 480]}
                sizes="(max-width: 719px) calc(100vw - 68px), (max-width: 959px) calc(50vw - 56px), 360px"
                quality={72}
                format="webp"
                loading="lazy"
              />
            </div>
            <div class="retail-product-card__body">
              <div class="retail-product-card__meta">
                <span class="pill">{category}</span>
                <span class="retail-product-card__weight">{view.weightLabel}</span>
              </div>
              <h3>{view.title}</h3>
              <a class="button button--secondary" href={view.mediaHref} aria-label={`Смотреть позицию: ${view.title}`}>Смотреть позицию</a>
            </div>
          </article>
        ))}
      </div>
      <div class="button-group retail-section-actions">
        <a class="button" href="/katalog/">Смотреть весь ассортимент</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHead eyebrow="После заявки" title="Что происходит после заявки" />
      <div class="simple-grid simple-grid--three">
        <article class="surface-card info-card"><h3>Уточняем задачу</h3><p>Связываемся с вами по указанным контактам, чтобы уточнить формат сотрудничества и цель обращения.</p></article>
        <article class="surface-card info-card"><h3>Обсуждаем ассортимент</h3><p>Рассматриваем подходящие позиции PASTODEL и возможный формат первого запуска.</p></article>
        <article class="surface-card info-card"><h3>Передаём доступную информацию</h3><p>По запросу направляем презентацию линейки и информацию об ассортименте для дальнейшего обсуждения.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <article class="surface-card info-card">
        <SectionHead compact eyebrow="Для согласования" title="Материалы для первого обсуждения" lead="По запросу предоставим доступные материалы о продукции PASTODEL:" />
        <ul class="detail-list">
          <li>презентацию линейки;</li>
          <li>информацию об ассортименте;</li>
          <li>информацию о форматах продукции;</li>
          <li>контакты для согласования дальнейших шагов.</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container pd-form-shell" id="partner-form">
      <form class="surface-card form-card" data-validated-form data-form-name="partneram-b2b" data-success-message="Спасибо. Заявка отправлена. Мы свяжемся с вами по указанным контактам." novalidate>
        <SectionHead eyebrow="Форма заявки" title="Обсудить ассортимент и сотрудничество" lead="Оставьте контакты и кратко укажите задачу. Мы свяжемся с вами по указанным контактам." />
        <div class="form-grid">
          <div class="field"><label for="partner-company">Название сети</label><input id="partner-company" name="company" type="text" placeholder="Название сети" data-required-field /><p class="pd-form-error" data-error-for="company"></p></div>
          <div class="field"><label for="partner-stores">Количество ТТ</label><input id="partner-stores" name="store_count" type="text" placeholder="Например, 25" data-required-field /><p class="pd-form-error" data-error-for="store_count"></p></div>
          <div class="field"><label for="partner-city">Город</label><input id="partner-city" name="city" type="text" placeholder="Город" data-required-field /><p class="pd-form-error" data-error-for="city"></p></div>
          <div class="field"><label for="partner-email">Email</label><input id="partner-email" name="email" type="email" placeholder="name@company.ru" data-required-field /><p class="pd-form-error" data-error-for="email"></p></div>
          <div class="field"><label for="partner-phone">Телефон</label><input id="partner-phone" name="phone" type="tel" inputmode="tel" placeholder="+7 (___) ___-__-__" data-required-field data-phone-field /><p class="pd-form-error" data-error-for="phone"></p></div>
          <div class="field field--full">
            <label for="partner-request-type">Тип запроса</label>
            <select id="partner-request-type" name="request_type" data-prefill-field="partner-request" data-query-param="request" data-query-map='{"conditions":"Запрос условий","commercial":"Коммерческое предложение","pilot":"Обсуждение пилота"}'>
              <option value="Запрос условий">Запрос условий</option>
              <option value="Коммерческое предложение">Коммерческое предложение</option>
              <option value="Обсуждение пилота">Обсуждение пилота</option>
            </select>
          </div>
        </div>
        <input type="hidden" name="product" value="" data-prefill-field="partner-product" data-query-param="product" />
        <label class="pd-checkbox"><input type="checkbox" name="privacy" required /><span>Я согласен с <a href="/politika-konfidentsialnosti/">политикой конфиденциальности</a> и обработкой персональных данных.</span></label>
        <p class="pd-form-error" data-error-for="privacy"></p>
        <div class="form-honeypot" aria-hidden="true"><label for="partner-company-site">Не заполняйте это поле</label><input id="partner-company-site" name="company_site" type="text" tabindex="-1" autocomplete="off" /></div>
        <div class="button-group"><button class="button" type="submit">Отправить заявку</button></div>
        <p class="pd-form-note">После отправки заявки мы свяжемся с вами по указанным контактам.</p>
        <p class="pd-form-error" data-form-request-error hidden></p>
        <p class="pd-form-success" data-form-success hidden>Спасибо. Заявка отправлена. Мы свяжемся с вами по указанным контактам.</p>
      </form>
    </div>
  </section>
  <FormRuntime />
</BaseLayout>

<style>
  .retail-product-grid {
    display: grid;
    gap: 18px;
  }

  .retail-product-card {
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
  }

  .retail-product-card__image {
    aspect-ratio: 1;
    padding: 18px;
    background: linear-gradient(180deg, #fffdf9f5, #efe4d7d4);
  }

  .retail-product-card__image :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .retail-product-card__body {
    display: grid;
    grid-template-rows: auto auto 1fr;
    gap: 14px;
    padding: 20px;
  }

  .retail-product-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .retail-product-card__weight {
    color: var(--brand-accent);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .retail-product-card h3 {
    margin: 0;
    font-size: 1.65rem;
  }

  .retail-product-card .button {
    align-self: end;
    justify-self: start;
  }

  .retail-section-actions {
    margin-top: 20px;
  }

  #partner-form {
    scroll-margin-top: 148px;
  }

  @media (min-width: 720px) {
    .retail-product-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 719px) {
    .retail-product-card .button {
      width: 100%;
    }
  }

  @media (max-width: 1023px) {
    #partner-form {
      scroll-margin-top: 118px;
    }
  }
</style>
