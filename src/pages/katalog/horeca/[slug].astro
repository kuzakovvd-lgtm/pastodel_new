---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductDetailPage from "@/components/product/ProductDetailPage.astro";
import { getProductSeo } from "@/data/product-seo";
import { getProductBySlug, getProducts } from "@/data/product-utils";

export function getStaticPaths() {
  return getProducts().map((product) => ({ params: { slug: product.slug } }));
}

const { slug } = Astro.params;
const product = slug ? getProductBySlug(slug) : undefined;

if (!product) {
  return Astro.redirect("/404/");
}

const seo = getProductSeo(product, "horeca");
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={new URL(seo.canonicalRoute, "https://pastodel.ru").toString()}
>
  <ProductDetailPage product={product} audience="horeca" />
</BaseLayout>
