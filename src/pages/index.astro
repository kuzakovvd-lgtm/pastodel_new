---
import BaseLayout from '@/layouts/BaseLayout.astro';

const homeCards = [
  {
    href: '/katalog/pasta-frikadelki-tomatny-sous/',
    title: 'Паста с фрикадельками и томатным соусом',
    text: 'Сочные мясные шарики, яркий томат, паста аль денте. Ужин, который никому не надоедает.',
    image: '/images/product-frikadelki.webp',
    meta: '400 г • От 7 минут • КБЖУ 198/9/6/25'
  },
  {
    href: '/katalog/karbonara/',
    title: 'Карбонара',
    text: 'Сливочный соус на основе сыра, кусочки бекона, паста. Классика, которая работает всегда.',
    image: '/images/product-karbonara.webp',
    meta: '400 г • От 7 минут • КБЖУ 228/9/11/24'
  },
  {
    href: '/katalog/rizotto-griby-slivochny-sous/',
    title: 'Ризотто с грибами',
    text: 'Рис в сливочном соусе с ароматом белых грибов. Ресторанное блюдо без ресторанного времени.',
    image: '/images/product-rizotto.webp',
    meta: '400 г • От 7 минут • КБЖУ 191/5/7/27'
  },
  {
    href: '/katalog/paelya-kuritsa-ovoshchi/',
    title: 'Паэлья с курицей и овощами',
    text: 'Рис, курица, болгарский перец. Самый яркий вкус в линейке.',
    image: '/images/product-paelya.webp',
    meta: '400 г • От 7 минут • КБЖУ 187/8/5/27'
  }
];
---
<BaseLayout
  title="Pastodel — ресторанная паста и готовые блюда | Купить оптом и в розницу"
  description="Готовые блюда Pastodel: паста, ризотто и паэлья. Ужин за 7 минут, честный состав, удобный формат для дома и решения для ритейла и HoReCa."
>
  <section class="hero-section">
    <div class="container hero-section__grid">
      <div class="hero-section__content">
        <p class="hero-section__eyebrow">ГОТОВО ЗА 7 МИНУТ</p>
        <h1>Карбонара. Ризотто. Паэлья. Готово за 7 минут.</h1>
        <p class="hero-section__subhead">400 г настоящей пасты или ризотто с соусом — просто разогрейте. Никаких полуфабрикатов, только готовое блюдо.</p>
        <div class="hero-section__actions">
          <a class="button" href="#home-hits">Выбрать вкус</a>
          <a class="button button--secondary" href="/partneram/">Для партнёров</a>
        </div>
      </div>
      <div class="hero-visual" role="img" aria-label="Визуальная композиция продукта Pastodel">
        <div class="hero-visual__frame">
          <div class="hero-visual__badge hero-visual__badge--time">7 минут</div>
          <div class="hero-visual__badge hero-visual__badge--weight">400 г</div>
          <img src="/images/hero-plate.webp" width="1080" height="1080" alt="Готовая паста Pastodel" loading="eager" fetchpriority="high" />
        </div>
      </div>
    </div>
  </section>

  <section class="home-section" id="home-hits">
    <div class="container">
      <p class="eyebrow">Хиты</p>
      <h2>Выберите вкус сегодняшнего ужина</h2>
      <p class="section-lead">11 блюд. Паста, ризотто, паэлья. От 7 минут.</p>
      <div class="product-grid">
        {homeCards.map((card) => (
          <article class="product-card">
            <a href={card.href} class="product-card__image">
              <img src={card.image} alt={card.title} width="1080" height="1080" loading="lazy" />
            </a>
            <div class="product-card__body">
              <p class="product-card__meta">{card.meta}</p>
              <h3><a href={card.href}>{card.title}</a></h3>
              <p>{card.text}</p>
              <div class="product-card__actions">
                <a class="button button--secondary" href={card.href}>Смотреть блюдо</a>
                <a href="/gde-kupit/">Где купить</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container cta-strip">
      <p class="eyebrow">B2B</p>
      <h2>Вы представитель сети или дистрибуции?</h2>
      <div class="button-group">
        <a class="button" href="/partneram/">Для партнёров</a>
        <a class="button button--secondary" href="/horeca/">Для HoReCa</a>
      </div>
    </div>
  </section>
</BaseLayout>
