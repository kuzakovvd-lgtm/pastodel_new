---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FormRuntime from "@/components/forms/FormRuntime.astro";
import ProductCard from "@/components/catalog/ProductCard.astro";
import { Image } from "astro:assets";
import heroPlate from "@/assets/home/hero-plate.webp";
import { getProducts } from "@/data/product-utils";
import type { ProductSlug } from "@/data/product-types";

const homeProductSlugs = [
  "pasta-frikadelki-tomatny-sous",
  "karbonara",
  "rizotto-griby-slivochny-sous",
  "paelya-kuritsa-ovoshchi",
] as const satisfies readonly ProductSlug[];

const productsBySlug = new Map(
  getProducts().map((product) => [product.slug, product] as const),
);
const homeProducts = homeProductSlugs.map((slug) => {
  const product = productsBySlug.get(slug);
  if (!product) throw new Error(`Missing homepage product: ${slug}`);
  return product;
});
---

<BaseLayout
  title="Pastodel — ресторанная паста и готовые блюда | Купить оптом и в розницу"
  description="Готовые блюда Pastodel: паста, ризотто и паэлья. Ужин за 7 минут, честный состав, удобный формат для дома и решения для ритейла и HoReCa."
>
  <section class="hero-section">
    <div class="container hero-section__grid">
      <div class="hero-section__content">
        <p class="hero-section__eyebrow">ГОТОВО ЗА 7 МИНУТ</p>
        <h1>Карбонара. Ризотто. Паэлья. Готово за 7 минут.</h1>
        <p class="hero-section__subhead">
          400 г настоящей пасты или ризотто с соусом — просто разогрейте.
          Никаких полуфабрикатов, только готовое блюдо.
        </p>
        <div class="hero-section__actions">
          <a class="button" href="#home-hits">Выбрать вкус</a>
          <a class="button button--secondary" href="/partneram/"
            >Для партнёров</a
          >
        </div>
      </div>
      <div
        class="hero-visual"
        role="img"
        aria-label="Визуальная композиция продукта Pastodel"
      >
        <div class="hero-visual__frame">
          <div class="hero-visual__badge hero-visual__badge--time">7 минут</div>
          <div class="hero-visual__badge hero-visual__badge--weight">400 г</div>
          <Image
            src={heroPlate}
            alt="Готовая паста Pastodel"
            widths={[220, 300, 420, 560]}
            sizes="(max-width: 719px) 265px, (max-width: 1279px) min(34vw, 390px), 390px"
            quality={60}
            loading="eager"
            fetchpriority="high"
            format="webp"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-audience-section" aria-labelledby="home-audience-title">
    <div class="container">
      <p class="eyebrow">Для дома и бизнеса</p>
      <h2 id="home-audience-title">Выберите свой сценарий</h2>
      <p class="section-lead">
        Перейдите в раздел, который соответствует вашей задаче.
      </p>
      <div class="simple-grid simple-grid--three audience-route-grid">
        <article class="surface-card audience-route-card">
          <div class="audience-route-card__head">
            <span class="audience-route-card__number" aria-hidden="true">01</span>
            <p class="audience-route-card__label">Покупателю</p>
          </div>
          <h3>Выбрать блюдо для дома</h3>
          <p class="audience-route-card__text">
            Посмотрите пасту, ризотто и паэлью, состав, КБЖУ и способы
            приготовления.
          </p>
          <a class="button button--secondary audience-route-card__cta" href="/katalog/">
            Смотреть ассортимент
          </a>
        </article>
        <article class="surface-card audience-route-card">
          <div class="audience-route-card__head">
            <span class="audience-route-card__number" aria-hidden="true">02</span>
            <p class="audience-route-card__label">Сетевому ритейлу</p>
          </div>
          <h3>Обсудить ассортимент для сети</h3>
          <p class="audience-route-card__text">
            Посмотрите линейку 400 г и оставьте заявку для обсуждения формата
            сотрудничества.
          </p>
          <a class="button button--secondary audience-route-card__cta" href="/partneram/">
            Для сетевого ритейла
          </a>
        </article>
        <article class="surface-card audience-route-card">
          <div class="audience-route-card__head">
            <span class="audience-route-card__number" aria-hidden="true">03</span>
            <p class="audience-route-card__label">HoReCa</p>
          </div>
          <h3>Обсудить продукт для кухни</h3>
          <p class="audience-route-card__text">
            Перейдите к профессиональному разделу и оставьте запрос на
            дегустацию или условия.
          </p>
          <a class="button button--secondary audience-route-card__cta" href="/horeca/">
            Для HoReCa
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <p class="eyebrow">Почему Pastodel</p>
      <h2>Почему Pastodel — это не обычная заморозка</h2>
      <div class="simple-grid simple-grid--four">
        <article class="surface-card info-card">
          <h3>Нормальная порция</h3><p>
            400 г — полноценный ужин для одного или лёгкий перекус на двоих.
          </p>
        </article>
        <article class="surface-card info-card">
          <h3>Вкусы, которые вы знаете</h3><p>
            Карбонара, альфредо, ризотто с грибами — блюда, которые не надо
            объяснять.
          </p>
        </article>
        <article class="surface-card info-card">
          <h3>Состав без сюрпризов</h3><p>
            В карточке любого блюда на сайте можно увидеть состав.
          </p>
        </article>
        <article class="surface-card info-card">
          <h3>Готово за 7 минут</h3><p>
            Разогрев в микроволновке или на плите без отдельной готовки
            ингредиентов.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="home-section" id="home-hits">
    <div class="container">
      <p class="eyebrow">Хиты</p>
      <h2>Выберите вкус сегодняшнего ужина</h2>
      <p class="section-lead">11 блюд. Паста, ризотто, паэлья. От 7 минут.</p>
      <div class="product-grid" id="home-product-grid">
        {
          homeProducts.map((product) => (
            <ProductCard product={product} audience="consumer" />
          ))
        }
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <p class="eyebrow">Доверие</p>
      <h2>Почему нам доверяют</h2>
      <div class="simple-grid simple-grid--three">
        <article class="surface-card info-card">
          <h3>Готово за минуты</h3><p>
            Продукт уже приготовлен — вам остаётся только разогреть и подать.
          </p>
        </article>
        <article class="surface-card info-card">
          <h3>Открытый состав</h3><p>
            В карточке каждого блюда — состав, КБЖУ и условия хранения.
          </p>
        </article>
        <article class="surface-card info-card">
          <h3>Удобно держать дома</h3><p>
            Это еда, которая выручает, когда нужен быстрый ужин без готовки.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container pd-form-shell" id="home-b2b-form">
      <form
        class="surface-card form-card"
        data-validated-form
        data-form-name="home-b2b"
        data-success-message="Спасибо. Заявка отправлена. Мы свяжемся с вами по указанным контактам."
        novalidate
      >
        <p class="eyebrow">Форма заявки</p>
        <h2>Стать партнёром</h2>
        <p class="section-lead">
          Оставьте контакты и кратко укажите задачу. Мы свяжемся с вами по
          указанным контактам.
        </p>
        <div class="form-grid">
          <div class="field">
            <label for="home-name">Имя</label><input
              id="home-name"
              name="name"
              type="text"
              placeholder="Как к вам обращаться"
              data-required-field
            /><p class="pd-form-error" data-error-for="name"></p>
          </div>
          <div class="field">
            <label for="home-company">Компания</label><input
              id="home-company"
              name="company"
              type="text"
              placeholder="Название компании"
              data-required-field
            /><p class="pd-form-error" data-error-for="company"></p>
          </div>
          <div class="field">
            <label for="home-email">Email</label><input
              id="home-email"
              name="email"
              type="email"
              placeholder="name@company.ru"
              data-required-field
            /><p class="pd-form-error" data-error-for="email"></p>
          </div>
          <div class="field">
            <label for="home-phone">Телефон</label><input
              id="home-phone"
              name="phone"
              type="tel"
              placeholder="+7 (___) ___-__-__"
              data-required-field
              data-phone-field
            /><p class="pd-form-error" data-error-for="phone"></p>
          </div>
        </div>
        <label class="pd-checkbox"
          ><input type="checkbox" name="privacy" required /><span
            >Я согласен с <a href="/politika-konfidentsialnosti/"
              >политикой конфиденциальности</a
            > и обработкой персональных данных.</span
          ></label
        >
        <p class="pd-form-error" data-error-for="privacy"></p>
        <div class="form-honeypot" aria-hidden="true">
          <label for="home-company-site">Не заполняйте это поле</label><input
            id="home-company-site"
            name="company_site"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
        </div>
        <div class="button-group">
          <button class="button" type="submit">Отправить заявку</button>
        </div>
        <p class="pd-form-note">
          После отправки заявки мы свяжемся с вами по указанным контактам.
        </p>
        <p class="pd-form-error" data-form-request-error hidden></p>
        <p class="pd-form-success" data-form-success hidden>
          Спасибо. Заявка отправлена. Мы свяжемся с вами по указанным контактам.
        </p>
      </form>
    </div>
  </section>
  <FormRuntime />
</BaseLayout>

<style>
  .audience-route-grid {
    margin-top: 24px;
  }

  .audience-route-card {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 14px;
    padding: 22px;
  }

  .audience-route-card__head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .audience-route-card__number {
    color: var(--brand-accent);
    font-weight: 600;
  }

  .audience-route-card__label {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .audience-route-card__text {
    margin: 0;
    color: var(--text-secondary);
  }

  .audience-route-card__cta {
    align-self: end;
    justify-self: start;
  }

  #home-product-grid {
    grid-auto-rows: 1fr;
  }

  #home-product-grid :global(.catalog-card) {
    display: flex;
    height: 100%;
    flex-direction: column;
  }

  #home-product-grid :global(.catalog-card__body) {
    flex: 1;
  }

  #home-product-grid :global(.catalog-card__actions) {
    margin-top: auto;
  }

  @media (max-width: 959px) {
    .audience-route-card__cta {
      width: 100%;
    }
  }
</style>
